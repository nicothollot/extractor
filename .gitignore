.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/*.lock

# setup transcript (local troubleshooting artifact)
setup_log.txt

# Generated synthetic PV tree (tests build it via tests/fixtures/build_fixture.py)
tests/fixtures/pv_root/
