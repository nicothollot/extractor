# Keep Windows batch files as CRLF bytes, untouched by EOL normalization —
# cmd.exe mis-parses LF-only .bat files (window flashes and closes).
*.bat -text
# PowerShell tolerates either; keep CRLF on checkout for Windows.
*.ps1 text eol=crlf
# Shell scripts must stay LF or they won't run on Linux/WSL/macOS.
*.sh text eol=lf
